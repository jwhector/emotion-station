# Copy this file to `.env.local` and fill in your Supabase project values.
# `.env.local` is gitignored. Vite only exposes vars prefixed with VITE_,
# and inlines them into the static bundle at BUILD time (no runtime server).
#
# In Vercel, set these same two vars under Project -> Settings -> Environment
# Variables (Production + Preview), then redeploy.
#
# The anon key is public by design; security rests on the row-level-security
# policies defined in supabase/schema.sql.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
